{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "cloud", "name": "Cloud", "color": "#F7F8F3" },
        { "slug": "rice", "name": "Rice", "color": "#FFFDF7" },
        { "slug": "mint-milk", "name": "Mint Milk", "color": "#DCEBDD" },
        { "slug": "pistachio", "name": "Pistachio", "color": "#BFD39B" },
        { "slug": "aqua-soft", "name": "Aqua Soft", "color": "#CDEAE8" },
        { "slug": "papaya", "name": "Papaya", "color": "#F6A27D" },
        { "slug": "coral-lab", "name": "Coral Lab", "color": "#E86F51" },
        { "slug": "butter-light", "name": "Butter Light", "color": "#FFE7A3" },
        { "slug": "cocoa", "name": "Cocoa", "color": "#594334" },
        { "slug": "ink-green", "name": "Ink Green", "color": "#253D34" },
        { "slug": "olive-gray", "name": "Olive Gray", "color": "#6B7466" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1160px"
